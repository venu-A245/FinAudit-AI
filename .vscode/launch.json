{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Python: Current File",
			"type": "python",
			"request": "launch",
			"program": "${file}",
			"console": "integratedTerminal",
			"justMyCode": true
		},
		{
			"name": "Streamlit: App",
			"type": "python",
			"request": "launch",
			"module": "streamlit",
			"args": ["run", "${workspaceFolder}/app.py"],
			"console": "integratedTerminal",
			"justMyCode": true
		}
	]
}
